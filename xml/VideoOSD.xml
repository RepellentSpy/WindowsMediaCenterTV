<?xml version="1.0" encoding="UTF-8"?>
<window>
	<defaultcontrol always="true">100100</defaultcontrol>
	<onload condition="!VideoPlayer.Content(LiveTV)">SetFocus(100100)</onload>
	<include>dialogeffect</include>
	<depth>DepthOSD</depth>
	<coordinates>
		<left>0</left>
		<top>0</top>
	</coordinates>
	<controls>
		<include>MainWindowMouseButtons</include>

		<!-- Assigned ID 6000 and an onleft return path to the left menu -->
		<control type="group" id="6000">
			<left>1020</left>
			<top>1000</top>
			<onleft>100100</onleft>
			<include>CommonNowPlaying_Controls</include>
		</control>
				
		<!-- Converted Left Menu to a standard group with manual pixel coordinates -->
		<control type="group" id="100100">
			<top>80r</top>
			<left>20</left>
			<height>50</height>
			<width>400</width>
			<defaultcontrol always="true">100104</defaultcontrol>
	
			<control type="image" id="100103">
				<left>0</left>
				<width>5</width>
				<texture />
			</control>

			<control type="togglebutton" id="100104">
				<left>6</left>
				<width>62</width>
				<height>50</height>
				<label>31351</label>
				<altlabel>208</altlabel>
				<font/>
				<texturefocus>vista\controls\CLOSEDCAPTIONS.FOCUS.png</texturefocus>
				<texturenofocus>vista\controls\CLOSEDCAPTIONS.NOFOCUS.png</texturenofocus>
				<usealttexture>!VideoPlayer.SubtitlesEnabled</usealttexture>
				<alttexturefocus>vista\controls\CLOSEDCAPTIONS.FOCUS.png</alttexturefocus>
				<alttexturenofocus>vista\controls\CLOSEDCAPTIONS.DISABLED.png</alttexturenofocus>
				<onclick>ShowSubtitles</onclick>
				<onright>100106</onright>
			</control>
	
			<control type="button" id="100106">
				<left>69</left>
				<width>62</width>
				<height>50</height>
				<label>31351</label>
				<altlabel>208</altlabel>
				<font/>
				<texturefocus>vista\controls\PLUS.FOCUS.png</texturefocus>
				<texturenofocus>vista\controls\PLUS.NOFOCUS.png</texturenofocus>
				<onclick>ActivateWindow(subtitlesearch)</onclick>
				<onleft>100104</onleft>
				<onright>100108</onright>
			</control>

			<control type="button" id="100108">
				<left>132</left>
				<width>62</width>
				<height>50</height>
				<label>31351</label>
				<altlabel>208</altlabel>
				<font/>
				<texturefocus>vista\controls\GUIDE.FOCUS.png</texturefocus>
				<texturenofocus>vista\controls\GUIDE.NOFOCUS.png</texturenofocus>
				<onclick>ActivateWindow(OSDSubtitleSettings)</onclick>
				<onleft>100106</onleft>
				<onright>100113</onright>
			</control>

			<control type="image">
				<left>195</left>
				<width>10</width>
				<aspectratio>keep</aspectratio>
				<texture>vista\controls\DIVIDER.png</texture>
			</control>

			<control type="button" id="100113">
				<left>206</left>
				<width>62</width>
				<height>50</height>
				<label>31351</label>
				<altlabel>208</altlabel>
				<font/>
				<texturefocus>vista\controls\MUTE.FOCUS.png</texturefocus>
				<texturenofocus>vista\controls\MUTE.NOFOCUS.png</texturenofocus>
				<onclick>ActivateWindow(OSDAudioSettings)</onclick>
				<onleft>100108</onleft>
				<onright>100117</onright>
			</control>

			<control type="image">
				<left>269</left>
				<width>10</width>
				<aspectratio>keep</aspectratio>
				<texture>vista\controls\DIVIDER.png</texture>
			</control>

			<control type="button" id="100117">
				<left>280</left>
				<width>62</width>
				<height>50</height>
				<label>31351</label>
				<altlabel>208</altlabel>
				<font/>
				<texturefocus>vista\controls\SUBTITLES.FOCUS.png</texturefocus>
				<texturenofocus>vista\controls\SUBTITLES.NOFOCUS.png</texturenofocus>
				<onclick>ActivateWindow(OSDVideoSettings)</onclick>
				<onleft>100113</onleft>
				<onright>6000</onright>
			</control>

			<control type="image" id="100120">
				<left>343</left>
				<width>10</width>
				<texture/>
			</control>
		</control>
		
		<control type="button" id="410">
			<description>Fake button for mouse control</description>
			<right>145</right>
			<bottom>60</bottom>
			<width>256</width>
			<height>250</height>
			<label/>
			<font/>
			<texturenofocus/>
			<texturefocus/>
			<animation effect="slide" start="0,0" end="55,0" time="0" condition="VideoPlayer.Content(LiveTV)">Conditional</animation>
			<visible>Control.HasFocus(410) | Control.HasFocus(250) | ControlGroup(400).HasFocus</visible>
		</control>
		<control type="button" id="520">
			<description>Fake button for mouse control</description>
			<right>200</right>
			<bottom>60</bottom>
			<width>256</width>
			<height>210</height>
			<label/>
			<font/>
			<texturenofocus/>
			<texturefocus/>
			<animation effect="slide" start="0,0" end="55,0" time="0" condition="VideoPlayer.Content(LiveTV)">Conditional</animation>
			<visible>Control.HasFocus(520) | Control.HasFocus(255) | ControlGroup(500).HasFocus</visible>
		</control>
		<control type="grouplist" id="500">
			<depth>DepthOSD+</depth>
			<visible>videoplayer.isstereoscopic + ![Window.IsVisible(SliderDialog) | Window.IsVisible(OSDSubtitleSettings) | Window.IsVisible(OSDVideoSettings) | Window.IsVisible(OSDAudioSettings) | Window.IsVisible(VideoBookmarks) | Window.IsVisible(PVROSDChannels) | Window.IsVisible(PVRChannelGuide)] + [Control.HasFocus(255) | ControlGroup(500).HasFocus | Control.HasFocus(520)]</visible>
			<animation effect="fade" time="150">VisibleChange</animation>
			<animation effect="slide" start="0,0" end="55,0" time="0" condition="![VideoPlayer.HasMenu | VideoPlayer.Content(LiveTV)]">Conditional</animation>
			<animation effect="slide" start="0,0" end="55,0" time="0" condition="VideoPlayer.Content(LiveTV)">Conditional</animation>
			<right>200</right>
			<bottom>45</bottom>
			<width>256</width>
			<height>220</height>
			<itemgap>0</itemgap>
			<onleft>100100</onleft>
			<onright>100100</onright>
			<onup>255</onup>
			<ondown>255</ondown>
			<orientation>vertical</orientation>
			<include>VisibleFadeEffect</include>
			<control type="group">
				<description>Header</description>
				<width>256</width>
				<height>40</height>
				<control type="image">
					<description>Header</description>
					<left>0</left>
					<top>0</top>
					<width>256</width>
					<height>40</height>
					<texture border="20,18,20,0">SubMenuBack-Header.png</texture>
				</control>
				<control type="label">
					<left>0</left>
					<top>20</top>
					<width>256</width>
					<height>15</height>
					<font>font12</font>
					<label>36501</label>
					<textcolor>blue</textcolor>
					<align>center</align>
					<aligny>center</aligny>
				</control>
			</control>
			<control type="radiobutton" id="503">
				<height>40</height>
				<width>256</width>
				<textoffsetx>30</textoffsetx>
				<aligny>center</aligny>
				<font>font13</font>
				<label>31362</label>
				<radioposx>200</radioposx>
				<texturefocus border="25,5,25,5">SubMenuBack-MiddleFO.png</texturefocus>
				<texturenofocus border="25,5,25,5">SubMenuBack-MiddleNF.png</texturenofocus>
				<onclick>ToggleStereoMode</onclick>
				<selected>Integer.IsGreater(System.StereoscopicMode,0)</selected>
				<pulseonselect>false</pulseonselect>
			</control>
			<control type="button" id="502">
				<height>40</height>
				<width>256</width>
				<aligny>center</aligny>
				<font>font13</font>
				<textoffsetx>30</textoffsetx>
				<texturefocus border="25,5,25,5">SubMenuBack-MiddleFO.png</texturefocus>
				<texturenofocus border="25,5,25,5">SubMenuBack-MiddleNF.png</texturenofocus>
				<pulseonselect>false</pulseonselect>
				<label>31361</label>
				<onclick>StereoMode</onclick>
			</control>
			<control type="radiobutton" id="501">
				<height>40</height>
				<width>256</width>
				<textoffsetx>30</textoffsetx>
				<aligny>center</aligny>
				<font>font13</font>
				<label>31360</label>
				<radioposx>200</radioposx>
				<texturefocus border="25,5,25,5">SubMenuBack-MiddleFO.png</texturefocus>
				<texturenofocus border="25,5,25,5">SubMenuBack-MiddleNF.png</texturenofocus>
				<onclick>StereoModeToMono</onclick>
				<selected>String.IsEqual(System.StereoscopicMode,9)</selected>
				<pulseonselect>false</pulseonselect>
			</control>
			<control type="image" id="549">
				<description>Footer</description>
				<width>256</width>
				<height>52</height>
				<texture border="20,0,20,50">SubMenuBack-Footer.png</texture>
			</control>
		</control>
	</controls>
</window>
